# Password auth for the web UI and phone pairing.
# Use OMNIHARNESS_AUTH_PASSWORD for a simple local setup.
# OMNIHARNESS_AUTH_PASSWORD=change-me
#
# Prefer OMNIHARNESS_AUTH_PASSWORD_HASH if this env file may be viewed by others.
# OMNIHARNESS_AUTH_PASSWORD_HASH=

# Optional: public or LAN origin for phone pairing and remote access links.
# OMNIHARNESS_PUBLIC_ORIGIN=https://example.trycloudflare.com

# Optional: supervisor model configuration. These can also be set in Settings.
# SUPERVISOR_LLM_PROVIDER=gemini
# SUPERVISOR_LLM_MODEL=gemini-3.1-pro-preview
# SUPERVISOR_LLM_API_KEY=
# SUPERVISOR_FALLBACK_LLM_PROVIDER=openai
# SUPERVISOR_FALLBACK_LLM_MODEL=gpt-5.4-mini
# SUPERVISOR_FALLBACK_LLM_API_KEY=

# Optional: agent provider API keys, if your local agent CLI is not already logged in.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# Optional: generic external credential profiles for ACP workers.
# OMNIHARNESS_CREDENTIAL_PROFILES_DIR=.omniharness/credential-profiles
# OMNIHARNESS_CREDENTIAL_PROFILE_CLAUDE=claude
# OMNIHARNESS_CREDENTIAL_COMMAND_CLAUDE=/Users/you/.local/bin/baton
# OMNIHARNESS_CREDENTIAL_COMMAND_ARGS_CLAUDE=["credential-profile"]

# Unified worker conversation stream (Phase 4 cutover — default ON). Set
# to 0/false/off to revert to the legacy messages-table reader path
# while the rollout settles. The flag is removed entirely in Phase 5.
# OMNI_UNIFIED_WORKER_STREAM=1
